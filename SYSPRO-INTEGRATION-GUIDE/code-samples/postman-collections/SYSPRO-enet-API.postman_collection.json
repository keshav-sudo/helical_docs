                "value": "application/xml"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<Query>\n  <Key>\n    <StockCode FilterType=\"A\" FilterValue=\"\"></StockCode>\n  </Key>\n  <Option>\n    <MaxRecords>100</MaxRecords>\n    <IncludeAllWarehouses>N</IncludeAllWarehouses>\n  </Option>\n</Query>"
            },
            "url": {
              "raw": "{{baseUrl}}/saborw/Query?BusinessObject=INVQRY&SessionId={{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["saborw", "Query"],
              "query": [
                { "key": "BusinessObject", "value": "INVQRY" },
                { "key": "SessionId", "value": "{{sessionId}}" }
              ]
            },
            "description": "Query all inventory items (limited to 100 records)"
          }
        },
        {
          "name": "Inventory Movement (INVTMM)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/xml"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<PostInvMovements>\n  <Item>\n    <Journal>IN</Journal>\n    <StockCode>WIDGET-001</StockCode>\n    <Warehouse>01</Warehouse>\n    <Quantity>10</Quantity>\n    <Reference>TEST-RECEIPT</Reference>\n    <Notation>Test inventory receipt</Notation>\n  </Item>\n</PostInvMovements>"
            },
            "url": {
              "raw": "{{baseUrl}}/saborw/Transaction?BusinessObject=INVTMM&SessionId={{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["saborw", "Transaction"],
              "query": [
                { "key": "BusinessObject", "value": "INVTMM" },
                { "key": "SessionId", "value": "{{sessionId}}" }
              ]
            },
            "description": "**Post inventory movement**\n\nJournal types:\n- IN = Receipt\n- OUT = Issue\n- ADJ = Adjustment\n- TRF = Transfer"
          }
        }
      ]
    },
