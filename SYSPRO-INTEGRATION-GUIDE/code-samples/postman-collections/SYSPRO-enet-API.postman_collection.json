      "item": [
        {
          "name": "Query Inventory (INVQRY)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/xml"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<Query>\n  <Key>\n    <StockCode>WIDGET-001</StockCode>\n  </Key>\n  <Option>\n    <IncludeAllWarehouses>Y</IncludeAllWarehouses>\n    <IncludeBins>N</IncludeBins>\n    <IncludeLots>N</IncludeLots>\n    <IncludeSerials>N</IncludeSerials>\n  </Option>\n</Query>"
            },
            "url": {
              "raw": "{{baseUrl}}/saborw/Query?BusinessObject=INVQRY&SessionId={{sessionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["saborw", "Query"],
              "query": [
                { "key": "BusinessObject", "value": "INVQRY" },
                { "key": "SessionId", "value": "{{sessionId}}" }
              ]
            },
            "description": "**Query inventory for a stock item**\n\nReturns:\n- Quantity on hand\n- Quantity available\n- Quantity allocated\n- Warehouse breakdown"
          }
        },
        {
          "name": "Query All Stock Codes",
